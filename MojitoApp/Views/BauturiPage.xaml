<Page x:Class="MojitoApp.Views.BauturiPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="#1A1A1A">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>


        <TabControl Grid.Row="1" Background="#1A1A1A"
                    BorderBrush="#C8A96E" BorderThickness="1">
            <TabControl.Resources>
                <Style TargetType="TabItem">
                    <Setter Property="Background" Value="#2A2A2A"/>
                    <Setter Property="Foreground" Value="#CCCCCC"/>
                    <Setter Property="Padding" Value="8,5"/>
                    <Style.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Background" Value="#C8A96E"/>
                            <Setter Property="Foreground" Value="#1A1A1A"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </TabControl.Resources>

            <TabItem Header="Ceaiuri">
                <ListView x:Name="listCeaiuri" Background="#2A2A2A"
                          BorderThickness="0" Foreground="White" FontSize="14"
                          SelectionChanged="list_SelectionChanged">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="Produs" Width="250" DisplayMemberBinding="{Binding Nume}"/>
                            <GridViewColumn Header="Volum" Width="80" DisplayMemberBinding="{Binding Gramaj}"/>
                            <GridViewColumn Header="Preț (MDL)" Width="100" DisplayMemberBinding="{Binding Pret}"/>
                        </GridView>
                    </ListView.View>
                </ListView>
            </TabItem>

            <TabItem Header="Cafea">
                <ListView x:Name="listCafea" Background="#2A2A2A"
                          BorderThickness="0" Foreground="White" FontSize="14"
                          SelectionChanged="list_SelectionChanged">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="Produs" Width="250" DisplayMemberBinding="{Binding Nume}"/>
                            <GridViewColumn Header="Volum" Width="80" DisplayMemberBinding="{Binding Gramaj}"/>
                            <GridViewColumn Header="Preț (MDL)" Width="100" DisplayMemberBinding="{Binding Pret}"/>
                        </GridView>
                    </ListView.View>
                </ListView>
            </TabItem>

            <TabItem Header="Fresh &amp; Soft">
                <ListView x:Name="listSoft" Background="#2A2A2A"
                          BorderThickness="0" Foreground="White" FontSize="14"
                          SelectionChanged="list_SelectionChanged">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="Produs" Width="250" DisplayMemberBinding="{Binding Nume}"/>
                            <GridViewColumn Header="Volum" Width="80" DisplayMemberBinding="{Binding Gramaj}"/>
                            <GridViewColumn Header="Preț (MDL)" Width="100" DisplayMemberBinding="{Binding Pret}"/>
                        </GridView>
                    </ListView.View>
                </ListView>
            </TabItem>

            <TabItem Header="Whisky">
                <ListView x:Name="listWhisky" Background="#2A2A2A"
                          BorderThickness="0" Foreground="White" FontSize="14"
                          SelectionChanged="list_SelectionChanged">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="Produs" Width="280" DisplayMemberBinding="{Binding Nume}"/>
                            <GridViewColumn Header="Volum" Width="70" DisplayMemberBinding="{Binding Gramaj}"/>
                            <GridViewColumn Header="Preț (MDL)" Width="100" DisplayMemberBinding="{Binding Pret}"/>
                        </GridView>
                    </ListView.View>
                </ListView>
            </TabItem>

            <TabItem Header="Vodcă &amp; Gin">
                <ListView x:Name="listVodcaGin" Background="#2A2A2A"
                          BorderThickness="0" Foreground="White" FontSize="14"
                          SelectionChanged="list_SelectionChanged">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="Produs" Width="280" DisplayMemberBinding="{Binding Nume}"/>
                            <GridViewColumn Header="Volum" Width="70" DisplayMemberBinding="{Binding Gramaj}"/>
                            <GridViewColumn Header="Preț (MDL)" Width="100" DisplayMemberBinding="{Binding Pret}"/>
                        </GridView>
                    </ListView.View>
                </ListView>
            </TabItem>

            <TabItem Header="Rom &amp; Tequila">
                <ListView x:Name="listRomTequila" Background="#2A2A2A"
                          BorderThickness="0" Foreground="White" FontSize="14"
                          SelectionChanged="list_SelectionChanged">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="Produs" Width="280" DisplayMemberBinding="{Binding Nume}"/>
                            <GridViewColumn Header="Volum" Width="70" DisplayMemberBinding="{Binding Gramaj}"/>
                            <GridViewColumn Header="Preț (MDL)" Width="100" DisplayMemberBinding="{Binding Pret}"/>
                        </GridView>
                    </ListView.View>
                </ListView>
            </TabItem>

            <TabItem Header="Coniac &amp; Divin">
                <ListView x:Name="listConiac" Background="#2A2A2A"
                          BorderThickness="0" Foreground="White" FontSize="14"
                          SelectionChanged="list_SelectionChanged">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="Produs" Width="280" DisplayMemberBinding="{Binding Nume}"/>
                            <GridViewColumn Header="Volum" Width="70" DisplayMemberBinding="{Binding Gramaj}"/>
                            <GridViewColumn Header="Preț (MDL)" Width="100" DisplayMemberBinding="{Binding Pret}"/>
                        </GridView>
                    </ListView.View>
                </ListView>
            </TabItem>

            <TabItem Header="Bere">
                <ListView x:Name="listBere" Background="#2A2A2A"
                          BorderThickness="0" Foreground="White" FontSize="14"
                          SelectionChanged="list_SelectionChanged">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="Produs" Width="250" DisplayMemberBinding="{Binding Nume}"/>
                            <GridViewColumn Header="Volum" Width="80" DisplayMemberBinding="{Binding Gramaj}"/>
                            <GridViewColumn Header="Preț (MDL)" Width="100" DisplayMemberBinding="{Binding Pret}"/>
                        </GridView>
                    </ListView.View>
                </ListView>
            </TabItem>

            <TabItem Header="Vin &amp; Șampanie">
                <ListView x:Name="listVin" Background="#2A2A2A"
                          BorderThickness="0" Foreground="White" FontSize="14"
                          SelectionChanged="list_SelectionChanged">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="Produs" Width="250" DisplayMemberBinding="{Binding Nume}"/>
                            <GridViewColumn Header="Volum" Width="80" DisplayMemberBinding="{Binding Gramaj}"/>
                            <GridViewColumn Header="Preț (MDL)" Width="100" DisplayMemberBinding="{Binding Pret}"/>
                        </GridView>
                    </ListView.View>
                </ListView>
            </TabItem>

        </TabControl>

        <!-- Cantitate + Total -->
        <Grid Grid.Row="2" Margin="0,15,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="120"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="Cantitate:"
                       Foreground="#C8A96E" FontSize="14"
                       VerticalAlignment="Center" Margin="0,0,10,0"/>
            <Grid Grid.Column="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="30"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="30"/>
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0" Content="-"
                        Background="#2A2A2A" Foreground="White"
                        BorderBrush="#C8A96E" BorderThickness="1"
                        FontSize="16" Cursor="Hand" Click="btnMinus_Click"/>
                <TextBox Grid.Column="1" x:Name="txtCantitate" Text="1"
                         FontSize="14" Background="#2A2A2A" Foreground="White"
                         BorderBrush="#C8A96E" BorderThickness="1"
                         TextAlignment="Center" VerticalContentAlignment="Center"/>
                <Button Grid.Column="2" Content="+"
                        Background="#2A2A2A" Foreground="White"
                        BorderBrush="#C8A96E" BorderThickness="1"
                        FontSize="16" Cursor="Hand" Click="btnPlus_Click"/>
            </Grid>
            <TextBlock Grid.Column="3" x:Name="txtTotal" Text="Total: 0 MDL"
                       Foreground="#C8A96E" FontSize="16" FontWeight="Bold"
                       VerticalAlignment="Center" Margin="20,0,0,0"/>
        </Grid>

        <Button Grid.Row="3" Content="🛒 ADAUGĂ ÎN COȘ"
                Height="48" Margin="0,5,0,0"
                Background="#C8A96E" Foreground="#1A1A1A"
                FontWeight="Bold" FontSize="14"
                BorderThickness="0" Cursor="Hand"
                Click="btnAdaugaInCos_Click"/>
    </Grid>
</Page>