<Page x:Class="MojitoApp.Views.RapoartePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="#1A1A1A">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TabControl Background="#1A1A1A" BorderBrush="#C8A96E" BorderThickness="1">
            <TabControl.Resources>
                <Style TargetType="TabItem">
                    <Setter Property="Background" Value="#2A2A2A"/>
                    <Setter Property="Foreground" Value="#CCCCCC"/>
                    <Setter Property="Padding" Value="10,5"/>
                    <Style.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Background" Value="#C8A96E"/>
                            <Setter Property="Foreground" Value="#1A1A1A"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </TabControl.Resources>

            <!-- Vanzari pe zi -->
            <TabItem Header="📅 Vânzări pe Zi">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Filtru data -->
                    <Grid Grid.Row="0" Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="160"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="160"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0" Text="De la:"
                                   Foreground="#C8A96E" FontSize="13"
                                   VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <DatePicker Grid.Column="1" x:Name="dpDeLa"
                                    Background="#2A2A2A" Foreground="White"
                                    BorderBrush="#C8A96E" BorderThickness="1"
                                    FontSize="13"/>
                        <TextBlock Grid.Column="2" Text="Până la:"
                                   Foreground="#C8A96E" FontSize="13"
                                   VerticalAlignment="Center" Margin="15,0,8,0"/>
                        <DatePicker Grid.Column="3" x:Name="dpPanaLa"
                                    Background="#2A2A2A" Foreground="White"
                                    BorderBrush="#C8A96E" BorderThickness="1"
                                    FontSize="13"/>
                        <Button Grid.Column="4" Content="🔍 FILTREAZĂ"
                                Height="34" Padding="15,0" Margin="10,0,0,0"
                                Background="#C8A96E" Foreground="#1A1A1A"
                                FontWeight="Bold" FontSize="12"
                                BorderThickness="0" Cursor="Hand"
                                Click="btnFiltra_Click"/>
                        <Button Grid.Column="5" Content="📅 AZI"
                                Height="34" Padding="15,0" Margin="10,0,0,0"
                                Background="Transparent" Foreground="#C8A96E"
                                BorderBrush="#C8A96E" BorderThickness="1"
                                FontSize="12" Cursor="Hand" HorizontalAlignment="Left"
                                Click="btnAzi_Click"/>
                    </Grid>

                    <ListView x:Name="listVanzari" Grid.Row="1"
                              Background="#2A2A2A" BorderThickness="0"
                              Foreground="White" FontSize="13">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="ID" Width="50"
                                                DisplayMemberBinding="{Binding Id}"/>
                                <GridViewColumn Header="Data și Ora" Width="150"
                                                DisplayMemberBinding="{Binding DataOra}"/>
                                <GridViewColumn Header="Angajat" Width="150"
                                                DisplayMemberBinding="{Binding NumeAngajat}"/>
                                <GridViewColumn Header="Produse" Width="50"
                                                DisplayMemberBinding="{Binding NrProduse}"/>
                                <GridViewColumn Header="Total (MDL)" Width="120"
                                                DisplayMemberBinding="{Binding Total}"/>
                            </GridView>
                        </ListView.View>
                    </ListView>

                    <!-- Total -->
                    <Border Grid.Row="2" Background="#2A2A2A"
                            BorderBrush="#C8A96E" BorderThickness="1"
                            Padding="15,10" Margin="0,10,0,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Name="txtNrComenzi"
                                       Text="Comenzi: 0"
                                       Foreground="#888888" FontSize="13"
                                       VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1" Text="TOTAL PERIOADĂ:"
                                       Foreground="#C8A96E" FontSize="15"
                                       FontWeight="Bold" VerticalAlignment="Center"
                                       Margin="0,0,15,0"/>
                            <TextBlock Grid.Column="2" x:Name="txtTotalPerioda"
                                       Text="0.00 MDL" Foreground="White"
                                       FontSize="18" FontWeight="Bold"
                                       VerticalAlignment="Center"/>
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>

            <!-- Top Produse -->
            <TabItem Header="🏆 Top Produse">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Button Grid.Row="0" Content="🔄 ACTUALIZEAZĂ"
                            Height="36" HorizontalAlignment="Left"
                            Padding="15,0" Margin="0,0,0,10"
                            Background="#C8A96E" Foreground="#1A1A1A"
                            FontWeight="Bold" FontSize="12"
                            BorderThickness="0" Cursor="Hand"
                            Click="btnActualizeazaTop_Click"/>

                    <ListView x:Name="listTop" Grid.Row="1"
                              Background="#2A2A2A" BorderThickness="0"
                              Foreground="White" FontSize="13">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="#" Width="40"
                                                DisplayMemberBinding="{Binding Pozitie}"/>
                                <GridViewColumn Header="Produs" Width="280"
                                                DisplayMemberBinding="{Binding Nume}"/>
                                <GridViewColumn Header="Cantitate Vândută" Width="150"
                                                DisplayMemberBinding="{Binding CantitateVanduta}"/>
                                <GridViewColumn Header="Total (MDL)" Width="120"
                                                DisplayMemberBinding="{Binding TotalMDL}"/>
                            </GridView>
                        </ListView.View>
                    </ListView>
                </Grid>
            </TabItem>

            <!-- Istoric Detaliat -->
            <TabItem Header="📋 Istoric Detaliat">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="200"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="ID Comandă:"
                                   Foreground="#C8A96E" FontSize="13"
                                   VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBox Grid.Column="1" x:Name="txtIdComanda"
                                 Height="34" FontSize="13"
                                 Background="#2A2A2A" Foreground="White"
                                 BorderBrush="#C8A96E" BorderThickness="1"
                                 Padding="8,0" VerticalContentAlignment="Center"/>
                        <Button Grid.Column="2" Content="🔍 CAUTĂ"
                                Height="34" Padding="15,0" Margin="10,0,0,0"
                                Background="#C8A96E" Foreground="#1A1A1A"
                                FontWeight="Bold" FontSize="12"
                                BorderThickness="0" Cursor="Hand"
                                Click="btnCautaComanda_Click"/>
                    </Grid>

                    <ListView x:Name="listDetalii" Grid.Row="1"
                              Background="#2A2A2A" BorderThickness="0"
                              Foreground="White" FontSize="13">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="Produs" Width="280"
                                                DisplayMemberBinding="{Binding NumeProdus}"/>
                                <GridViewColumn Header="Cantitate" Width="100"
                                                DisplayMemberBinding="{Binding Cantitate}"/>
                                <GridViewColumn Header="Preț Unitar" Width="120"
                                                DisplayMemberBinding="{Binding PretUnitar}"/>
                                <GridViewColumn Header="Subtotal" Width="120"
                                                DisplayMemberBinding="{Binding Subtotal}"/>
                            </GridView>
                        </ListView.View>
                    </ListView>
                </Grid>
            </TabItem>

        </TabControl>
    </Grid>
</Page>