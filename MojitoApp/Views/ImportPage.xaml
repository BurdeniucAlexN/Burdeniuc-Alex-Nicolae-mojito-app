<Page x:Class="MojitoApp.Views.ImportPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="#1A1A1A">

    <Grid Margin="20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="20"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- STANGA: introducere text -->
        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="📋 Introduceți lista de produse:"
                       Foreground="#C8A96E" FontSize="15" FontWeight="Bold"
                       Margin="0,0,0,8"/>

            <TextBlock Grid.Row="0" Text="Format: Nume Produs [cantitate]  (ex: Salata Caesar cu pui 4)"
                       Foreground="#888888" FontSize="11"
                       Margin="0,28,0,8"/>

            <TextBox Grid.Row="1" x:Name="txtInput"
                     Background="#2A2A2A" Foreground="White"
                     BorderBrush="#C8A96E" BorderThickness="1"
                     FontSize="14" AcceptsReturn="True"
                     VerticalScrollBarVisibility="Auto"
                     TextWrapping="Wrap" Padding="10"
                     VerticalContentAlignment="Top"
                     FontFamily="Consolas"/>

            <Button Grid.Row="2" Content="🔍 PROCESEAZĂ LISTA"
                    Height="48" Margin="0,15,0,5"
                    Background="#C8A96E" Foreground="#1A1A1A"
                    FontWeight="Bold" FontSize="14"
                    BorderThickness="0" Cursor="Hand"
                    Click="btnProceseaza_Click"/>

            <Button Grid.Row="3" Content="🗑 GOLEȘTE"
                    Height="36" Margin="0,0,0,0"
                    Background="Transparent" Foreground="#E74C3C"
                    BorderBrush="#E74C3C" BorderThickness="1"
                    FontSize="12" Cursor="Hand"
                    Click="btnGoleste_Click"/>
        </Grid>

        <!-- DREAPTA: preview rezultate -->
        <Grid Grid.Column="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="✅ Preview comandă:"
                       Foreground="#C8A96E" FontSize="15" FontWeight="Bold"
                       Margin="0,0,0,36"/>

            <ListView x:Name="listPreview" Grid.Row="1"
                      Background="#2A2A2A" BorderThickness="0"
                      Foreground="White" FontSize="13">
                <ListView.View>
                    <GridView>
                        <GridViewColumn Header="Produs" Width="200"
                                        DisplayMemberBinding="{Binding Nume}"/>
                        <GridViewColumn Header="Cant" Width="50"
                                        DisplayMemberBinding="{Binding Cantitate}"/>
                        <GridViewColumn Header="Preț" Width="80"
                                        DisplayMemberBinding="{Binding Pret}"/>
                        <GridViewColumn Header="Total" Width="80"
                                        DisplayMemberBinding="{Binding Subtotal}"/>
                        <GridViewColumn Header="Status" Width="80">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Status}"
                                               Foreground="{Binding StatusColor}"
                                               FontWeight="Bold"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                    </GridView>
                </ListView.View>
            </ListView>

            <!-- Total -->
            <Border Grid.Row="2" Background="#2A2A2A"
                    BorderBrush="#C8A96E" BorderThickness="1"
                    Padding="15,10" Margin="0,10,0,5">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="TOTAL COMANDĂ:"
                               Foreground="#C8A96E" FontSize="15"
                               FontWeight="Bold" VerticalAlignment="Center"/>
                    <TextBlock x:Name="txtTotal" Grid.Column="1"
                               Text="0.00 MDL" Foreground="White"
                               FontSize="18" FontWeight="Bold"
                               VerticalAlignment="Center"/>
                </Grid>
            </Border>

            <Button Grid.Row="3" Content="✅ CONFIRMĂ ȘI SCADE STOC"
                    Height="48" Margin="0,0,0,0"
                    Background="#C8A96E" Foreground="#1A1A1A"
                    FontWeight="Bold" FontSize="14"
                    BorderThickness="0" Cursor="Hand"
                    Click="btnConfirma_Click"/>
        </Grid>
    </Grid>
</Page>