<Window x:Class="MojitoApp.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Mojito — Login" Height="500" Width="420"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#1A1A1A">

    <Grid>
        <StackPanel VerticalAlignment="Center" Margin="50,0">

            <!-- Logo / Titlu -->
            <Image Source="/Assets/logo.png"
       Height="90" Width="90"
       HorizontalAlignment="Center"
       Margin="0,0,0,16"/>
            <TextBlock Text="Opera Magna SRL"
                       FontSize="13" Foreground="#888888"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,40"/>

            <!-- Username -->
            <TextBlock Text="Username" Foreground="#C8A96E"
                       FontSize="12" Margin="0,0,0,6"/>
            <TextBox x:Name="txtUsername"
                     Height="42" FontSize="14"
                     Background="#2A2A2A" Foreground="White"
                     BorderBrush="#C8A96E" BorderThickness="1"
                     Padding="10,0" CaretBrush="White"/>

            <!-- Parola -->
            <TextBlock Text="Parolă" Foreground="#C8A96E"
                       FontSize="12" Margin="0,20,0,6"/>
            <PasswordBox x:Name="txtParola"
                         Height="42" FontSize="14"
                         Background="#2A2A2A" Foreground="White"
                         BorderBrush="#C8A96E" BorderThickness="1"
                         Padding="10,0"/>

            <!-- Mesaj eroare -->
            <TextBlock x:Name="txtEroare"
                       Foreground="#E74C3C" FontSize="12"
                       HorizontalAlignment="Center"
                       Margin="0,12,0,0" Visibility="Collapsed"/>

            <!-- Buton Login -->
            <Button x:Name="btnLogin" Content="AUTENTIFICARE"
                    Height="44" Margin="0,24,0,0"
                    Background="#C8A96E" Foreground="#1A1A1A"
                    FontWeight="Bold" FontSize="14"
                    BorderThickness="0" Cursor="Hand"
                    Click="btnLogin_Click"/>

        </StackPanel>
    </Grid>
</Window>