<Page x:Class="MojitoApp.Views.AngajatiPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="#1A1A1A">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TabControl Grid.Row="0" Background="#1A1A1A"
                    BorderBrush="#C8A96E" BorderThickness="1">
            <TabControl.Resources>
                <Style TargetType="TabItem">
                    <Setter Property="Background" Value="#2A2A2A"/>
                    <Setter Property="Foreground" Value="#CCCCCC"/>
                    <Setter Property="Padding" Value="10,5"/>
                    <Style.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Background" Value="#C8A96E"/>
                            <Setter Property="Foreground" Value="#1A1A1A"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </TabControl.Resources>

            <!-- Lista Angajati -->
            <TabItem Header="👥 Listă Angajați">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <ListView x:Name="listAngajati" Grid.Row="0"
                              Background="#2A2A2A" BorderThickness="0"
                              Foreground="White" FontSize="14">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="ID" Width="50"
                                                DisplayMemberBinding="{Binding Id}"/>
                                <GridViewColumn Header="Nume" Width="150"
                                                DisplayMemberBinding="{Binding Nume}"/>
                                <GridViewColumn Header="Prenume" Width="150"
                                                DisplayMemberBinding="{Binding Prenume}"/>
                                <GridViewColumn Header="Username" Width="120"
                                                DisplayMemberBinding="{Binding Username}"/>
                                <GridViewColumn Header="Rol" Width="100">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Rol}"
                                                       Foreground="{Binding RolColor}"
                                                       FontWeight="Bold"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                            </GridView>
                        </ListView.View>
                    </ListView>

                    <Button Grid.Row="1" Content="🗑 DEZACTIVEAZĂ ANGAJAT SELECTAT"
                            Height="40" Margin="0,10,0,0"
                            Background="Transparent" Foreground="#E74C3C"
                            BorderBrush="#E74C3C" BorderThickness="1"
                            FontSize="13" Cursor="Hand"
                            Click="btnDezactiveaza_Click"/>
                </Grid>
            </TabItem>

            <!-- Adaugare Angajat -->
            <TabItem Header="➕ Angajat Nou">
                <Grid Margin="20">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="150"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Nume:"
                               Foreground="#C8A96E" FontSize="14"
                               VerticalAlignment="Center" Margin="0,0,0,15"/>
                    <TextBox Grid.Row="0" Grid.Column="1" x:Name="txtNume"
                             Height="36" FontSize="14" Margin="0,0,0,15"
                             Background="#2A2A2A" Foreground="White"
                             BorderBrush="#C8A96E" BorderThickness="1"
                             Padding="8,0" VerticalContentAlignment="Center"/>

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Prenume:"
                               Foreground="#C8A96E" FontSize="14"
                               VerticalAlignment="Center" Margin="0,0,0,15"/>
                    <TextBox Grid.Row="1" Grid.Column="1" x:Name="txtPrenume"
                             Height="36" FontSize="14" Margin="0,0,0,15"
                             Background="#2A2A2A" Foreground="White"
                             BorderBrush="#C8A96E" BorderThickness="1"
                             Padding="8,0" VerticalContentAlignment="Center"/>

                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Username:"
                               Foreground="#C8A96E" FontSize="14"
                               VerticalAlignment="Center" Margin="0,0,0,15"/>
                    <TextBox Grid.Row="2" Grid.Column="1" x:Name="txtUsername"
                             Height="36" FontSize="14" Margin="0,0,0,15"
                             Background="#2A2A2A" Foreground="White"
                             BorderBrush="#C8A96E" BorderThickness="1"
                             Padding="8,0" VerticalContentAlignment="Center"/>

                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Parolă:"
                               Foreground="#C8A96E" FontSize="14"
                               VerticalAlignment="Center" Margin="0,0,0,15"/>
                    <PasswordBox Grid.Row="3" Grid.Column="1" x:Name="txtParola"
                                 Height="36" FontSize="14" Margin="0,0,0,15"
                                 Background="#2A2A2A" Foreground="White"
                                 BorderBrush="#C8A96E" BorderThickness="1"
                                 Padding="8,0"/>

                    <TextBlock Grid.Row="4" Grid.Column="0" Text="Rol:"
                               Foreground="#C8A96E" FontSize="14"
                               VerticalAlignment="Center" Margin="0,0,0,15"/>
                    <ComboBox Grid.Row="4" Grid.Column="1" x:Name="cmbRol"
                              Height="36" FontSize="14" Margin="0,0,0,15"
                              Background="#2A2A2A" Foreground="White"
                              BorderBrush="#C8A96E" BorderThickness="1">
                        <ComboBoxItem Content="chelner" IsSelected="True"/>
                        <ComboBoxItem Content="admin"/>
                    </ComboBox>

                    <TextBlock Grid.Row="5" Grid.Column="1"
                               x:Name="txtEroareAngajat"
                               Foreground="#E74C3C" FontSize="12"
                               Margin="0,0,0,10" Visibility="Collapsed"/>

                    <Button Grid.Row="6" Grid.Column="1"
                            Content="✅ ADAUGĂ ANGAJAT"
                            Height="44" Background="#C8A96E"
                            Foreground="#1A1A1A" FontWeight="Bold"
                            FontSize="14" BorderThickness="0"
                            Cursor="Hand" Click="btnAdaugaAngajat_Click"/>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</Page>