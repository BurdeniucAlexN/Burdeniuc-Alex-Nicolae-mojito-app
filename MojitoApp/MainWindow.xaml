<Window x:Class="MojitoApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Mojito — Gestiune" Height="700" Width="1200"
        WindowStartupLocation="CenterScreen"
        Background="#1A1A1A">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="280"/>
        </Grid.ColumnDefinitions>

        <!-- SIDEBAR -->
        <Border Grid.Column="0" Background="#111111"
                BorderBrush="#C8A96E" BorderThickness="0,0,1,0">
            <StackPanel>
                <StackPanel Background="#0D0D0D" Height="120">
                    <Image Source="/Assets/logo.png" Height="55"
                           Margin="0,15,0,5" HorizontalAlignment="Center"/>
                    <TextBlock x:Name="txtAngajat" Text="Admin"
                               FontSize="12" Foreground="#888888"
                               HorizontalAlignment="Center"/>
                </StackPanel>

                <Button Content="🍽  Bucătărie Europeană"
                        Style="{StaticResource NavButton}"
                        Click="Nav_Click" Tag="european"/>
                <Button Content="🍣  Bucătărie Japoneză"
                        Style="{StaticResource NavButton}"
                        Click="Nav_Click" Tag="japonez"/>
                <Button Content="🍹  Bar &amp; Cocktailuri"
                        Style="{StaticResource NavButton}"
                        Click="Nav_Click" Tag="bar"/>
                <Button Content="🥤  Băuturi"
                        Style="{StaticResource NavButton}"
                        Click="Nav_Click" Tag="bauturi"/>
                <Button Content="📦  Stocuri"
                        Style="{StaticResource NavButton}"
                        Click="Nav_Click" Tag="stocuri"/>
                <Button Content="📊  Rapoarte"
                        Style="{StaticResource NavButton}"
                        Click="Nav_Click" Tag="rapoarte"/>
                <Button Content="👥  Angajați"
                        Style="{StaticResource NavButton}"
                        Click="Nav_Click" Tag="angajati"/>
                <Button Content="📋  Import Comandă"
                        Style="{StaticResource NavButton}"
                        Click="Nav_Click" Tag="import"/>

                <Button Content="⏻  Deconectare"
                        Margin="15,40,15,0" Height="38"
                        Background="Transparent"
                        BorderBrush="#C8A96E" BorderThickness="1"
                        Foreground="#C8A96E" FontSize="13"
                        Cursor="Hand" Click="Logout_Click"/>
            </StackPanel>
        </Border>

        <!-- CONTENT AREA -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="55"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="#111111"
                    BorderBrush="#C8A96E" BorderThickness="0,0,0,1">
                <TextBlock x:Name="txtPagina"
                           Text="Bun venit la Mojito"
                           FontSize="20" FontWeight="Bold"
                           Foreground="#C8A96E"
                           VerticalAlignment="Center"
                           Margin="25,0,0,0"/>
            </Border>

            <Frame x:Name="MainFrame" Grid.Row="1"
                   Background="#1A1A1A"
                   NavigationUIVisibility="Hidden"/>
        </Grid>

        <!-- COS COMENZI -->
        <Border Grid.Column="2" Background="#111111"
                BorderBrush="#C8A96E" BorderThickness="1,0,0,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="55"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Header cos -->
                <Border Grid.Row="0" Background="#0D0D0D"
                        BorderBrush="#C8A96E" BorderThickness="0,0,0,1">
                    <TextBlock Text="🛒 Comandă curentă"
                               FontSize="16" FontWeight="Bold"
                               Foreground="#C8A96E"
                               VerticalAlignment="Center"
                               Margin="15,0,0,0"/>
                </Border>

                <!-- Lista produse in cos -->
                <ListView x:Name="listCos" Grid.Row="1"
                          Background="#111111"
                          BorderThickness="0"
                          Foreground="White"
                          FontSize="12">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="Produs" Width="120"
                                            DisplayMemberBinding="{Binding Nume}"/>
                            <GridViewColumn Header="Cant" Width="35"
                                            DisplayMemberBinding="{Binding Cantitate}"/>
                            <GridViewColumn Header="Preț" Width="65"
                                            DisplayMemberBinding="{Binding Subtotal}"/>
                        </GridView>
                    </ListView.View>
                </ListView>

                <!-- Total -->
                <Border Grid.Row="2" Background="#0D0D0D"
                        BorderBrush="#C8A96E" BorderThickness="0,1,0,1"
                        Padding="15,10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="TOTAL:" FontSize="16"
                                   FontWeight="Bold" Foreground="#C8A96E"
                                   VerticalAlignment="Center"/>
                        <TextBlock x:Name="txtTotalCos" Grid.Column="1"
                                   Text="0 MDL" FontSize="18"
                                   FontWeight="Bold" Foreground="White"
                                   VerticalAlignment="Center"/>
                    </Grid>
                </Border>

                <!-- Butoane cos -->
                <Button Grid.Row="3"
                        Content="✅ FINALIZEAZĂ COMANDA"
                        Height="48" Margin="10,10,10,5"
                        Background="#C8A96E" Foreground="#1A1A1A"
                        FontWeight="Bold" FontSize="13"
                        BorderThickness="0" Cursor="Hand"
                        Click="btnFinalizare_Click"/>

                <Button Grid.Row="4"
                        Content="🗑 GOLEȘTE COȘUL"
                        Height="36" Margin="10,0,10,10"
                        Background="Transparent"
                        BorderBrush="#E74C3C" BorderThickness="1"
                        Foreground="#E74C3C" FontSize="12"
                        Cursor="Hand" Click="btnGolesteCos_Click"/>
            </Grid>
        </Border>
    </Grid>
</Window>